# AI Import Tool — Configuration
# Copy this file to .env and fill in your values

# Your ContestHub server URL (e.g. https://your-app.railway.app)
# Used only when AI_IMPORT_DELIVERY=api or auto fallback reaches the API.
SERVER_URL=http://localhost:4000

# Delivery mode:
# - direct-db (default): insert through server/scripts/ai-import-direct.js using DATABASE_URL/POSTGRES_URL.
# - api: POST to SERVER_URL/api/import with AI_IMPORT_API_KEY.
# - auto: try direct-db, then api.
AI_IMPORT_DELIVERY=direct-db
AI_IMPORT_DIRECT_TIMEOUT_SECONDS=60
# Optional: pin the Node executable used by direct-db mode.
# Useful when a non-LTS system Node appears earlier in PATH.
AI_IMPORT_NODE=node

# Database URL for direct-db mode. You can also keep this in the repo root .env.
DATABASE_URL=

# API key — used only for AI_IMPORT_DELIVERY=api or auto fallback.
# Must match AI_IMPORT_API_KEY in server .env.
AI_IMPORT_API_KEY=change_me

# AI provider: codex, ollama, or auto
# Use codex when the local machine cannot run large Ollama models.
AI_PROVIDER=codex

# Codex CLI fallback settings
CODEX_COMMAND=codex
# Leave blank to use the default model from your Codex CLI config.
CODEX_MODEL=
CODEX_TIMEOUT_SECONDS=300
MAX_URL_TEXT_CHARS=20000
MAX_URL_METADATA_CHARS=8000
MAX_IMAGE_CANDIDATES=12
MAX_LINK_CANDIDATES=12
MAX_RELATED_PAGES=2
MAX_RELATED_PAGE_TEXT_CHARS=5000
MAX_STRUCTURED_DATA_ITEMS=24

# Ollama settings (optional local fallback)
OLLAMA_HOST=http://localhost:11434
# Text/URL extraction:
OLLAMA_MODEL=qwen2.5vl:7b
# Image extraction:
OLLAMA_VISION_MODEL=qwen2.5vl:7b
# Lower this if Ollama reports "model requires more system memory".
OLLAMA_NUM_CTX=1024
