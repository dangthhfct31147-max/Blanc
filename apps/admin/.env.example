# Admin Panel Environment Variables

# `VITE_*` values are public client-side config. Do not place secrets here.

# API URL - same-site backend in production, local backend in development.
VITE_API_URL=/api

# For local development, you can override with:
# VITE_API_URL=http://localhost:4000/api

# Public site base URL (for profile links)
VITE_PUBLIC_SITE_URL=https://blanc.up.railway.app

# AI features are served by the backend; set `GEMINI_API_KEY` on the API server.
